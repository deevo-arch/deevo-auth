# ─── Deevo OAuth Test App Configuration ───────────────────────────
# 
# 1. Go to your Deevo auth server → /developers
# 2. Create a new app with:
#      Name: Test App
#      Redirect URI: http://localhost:3001/auth/callback
# 3. Copy the credentials below:

DEEVO_CLIENT_ID=your_client_id_here
DEEVO_CLIENT_SECRET=your_client_secret_here

# URL of your running Deevo auth server (default: localhost:3000)
DEEVO_AUTH_SERVER=http://localhost:3000

# Port for this test app (default: 3001)
PORT=3001

# Base URL of this test app (must match the redirect URI registered above)
BASE_URL=http://localhost:3001
